# Supabase project settings (Project Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string for the same Supabase project
# (Project Settings -> Database -> Connection string -> URI)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Groq (chat + tool calling)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (embeddings)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional: Slack webhook for the send_slack_summary tool.
# Leave blank to disable -- the tool will log a graceful error instead of
# crashing if it's called with no webhook configured.
SLACK_WEBHOOK_URL=

ENVIRONMENT=development

# CORS allow_origins. Comma-separated if you need more than one (e.g. your
# deployed Vercel URL plus localhost while testing):
# FRONTEND_URL=https://siloed.vercel.app,http://localhost:5173

FRONTEND_URL=http://localhost:5173